# === SUPABASE ===
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGci...
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# === DATABASE (Supabase PostgreSQL) ===
DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres

# === AUTH ===
JWT_SECRET=tu-clave-secreta-larga-aqui-cambiar-en-produccion
JWT_EXPIRES_IN=24h
# Refresh token (renovación de sesión). Si JWT_REFRESH_SECRET se deja vacío,
# se deriva automáticamente de JWT_SECRET.
JWT_REFRESH_SECRET=otra-clave-secreta-distinta-para-refresh
JWT_REFRESH_EXPIRES_IN=7d

# === LM STUDIO (VLM para extracción de menú con IA) ===
LM_STUDIO_URL=http://localhost:1234/v1
# Opcional: id del modelo de visión en LM Studio (ej. google/gemma-4-e4b).
# Si se deja vacío, se usa el modelo que tengas cargado en LM Studio.
LM_STUDIO_MODEL=

# === FRONTEND ===
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# === BACKEND ===
PORT=3001
NODE_ENV=development
